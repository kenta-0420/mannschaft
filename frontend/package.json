{
  "name": "mannschaft-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "prepare": "husky",
    "test": "vitest run && playwright test",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
  "lint-staged": {
    "*.{ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@nuxt/image": "^2.0.0",
    "@nuxtjs/i18n": "^9.5.3",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@pinia/nuxt": "^0.11.3",
    "@primeuix/themes": "^2.0.3",
    "@primevue/nuxt-module": "^4.5.4",
    "@primevue/themes": "^4.5.4",
    "@types/dompurify": "^3.0.5",
    "@vee-validate/zod": "^4.15.1",
    "@vite-pwa/nuxt": "^1.1.1",
    "@vueuse/nuxt": "^14.2.1",
    "chart.js": "^4.5.1",
    "dayjs": "^1.11.20",
    "dexie": "^4.4.2",
    "dompurify": "^3.3.3",
    "marked": "^17.0.5",
    "nuxt": "^3.21.2",
    "ofetch": "^1.5.1",
    "pinia": "^3.0.4",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.4",
    "tailwindcss-primeui": "^0.6.1",
    "vee-validate": "^4.15.1",
    "vue": "latest",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/test-utils": "^4.0.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.0",
    "@vue/test-utils": "^2.4.6",
    "dotenv": "^17.4.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.8.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "otplib": "^13.4.0",
    "prettier": "^3.8.1",
    "vitest": "^4.1.0"
  }
}
